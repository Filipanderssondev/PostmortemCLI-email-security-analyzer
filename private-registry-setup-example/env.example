# ~/.postmortemcli/.env
# Copy this file to ~/.postmortemcli/.env and fill in your values.
# Never commit this file to version control.

# ── Private registry ────────────────────────────────────────────
# Address of your private container registry (e.g. Harbor)
PRIVATE_REGISTRY=registry.your-org.example.com

# Project or namespace inside the registry
PROJECT_NAMESPACE=your-project/postmortemcli

# ── Image server ────────────────────────────────────────────────
# SSH address of the server used for Trivy scanning and buildah operations
# This server must have internet access to reach Docker Hub
IMAGE_SERVER=user@image-server.your-org.example.com

# ── Registry credentials ─────────────────────────────────────────
# Username and password for your private registry
REGISTRY_USERNAME=your-username
REGISTRY_PASSWORD=your-password
